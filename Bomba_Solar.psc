Algoritmo Bomba_Solar
	Escribir "El estado de funcionamiento de la bomba solar";
	Escribir "Ingresar la cantidad de irradiacion solar actual";
	Definir Bomba Como Entero;
	Leer Bomba;
	si Bomba>400 Entonces
		Escribir "bomba encendida";
	SiNo
		Escribir "bomba apagada";
	FinSi
FinAlgoritmo